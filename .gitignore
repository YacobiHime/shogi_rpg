# --- 依存関係・ビルド成果物 ---
node_modules/
dist/
build/
*.log
.DS_Store
Thumbs.db

# --- 開発補助ツール（cshogi/python-shogi等の環境） ---
tools/venv/
tools/__pycache__/
*.pyc

# --- ライセンス保留中の素材（暫定対応） ---
# 振電3（Shinden3）評価関数・実行ファイル：
# 開発者本人が無償公開を明言しているが、正式なライセンス文書がなく
# 再配布可否が未確認のため、確認が取れるまでリポジトリの管理対象から除外する。
# 詳細: docs/ASSETS_CREDITS.md および docs/SYSTEM_DESIGN.md 8.1 を参照
ShogiAI/Shinden3/eval/
ShogiAI/Shinden3/*.exe

# ローカル検証専用ディレクトリ（gitで管理しない実験用置き場）
/local-only/

# --- M0技術検証用WASMファイル ---
# arashigaoka/YaneuraOu.wasm v0.1.2 のバイナリファイル
# 検証用として tools/m0-verification/ 配下に配置するが、リポジトリにはコミットしない
tools/m0-verification/*.js
tools/m0-verification/*.wasm
tools/m0-verification/*.data
# 検証用HTML/JSはコミット対象とする
!tools/m0-verification/index.html
!tools/m0-verification/worker.js

# --- M1対局UI: vendorディレクトリ（外部ライブラリのビルド成果物） ---
# shogi.js (npm install shogi.js) と YaneuraOu.wasm (npm install yaneuraou.wasm) を
# ビルドツールなしでブラウザから直接読み込むためにコピーする配置場所。
# tools/m0-verification と同じ方針で、コピーした成果物自体はコミットしない。
# 配置手順は src/board-ui/README.md を参照。
src/board-ui/vendor/*
!src/board-ui/vendor/.gitkeep

# yaneuraou.jsは.dataファイルをindex.html基準の相対パスでfetchするため、
# vendor/とは別にindex.htmlと同じ階層にも配置が必要（README参照）
src/board-ui/yaneuraou.data

# 開発用HTTPサーバー（COOP/COEP対応、各自の環境で用意する。tools/m0-verificationと同じ方針）
src/board-ui/server.js

# --- 大容量バイナリの誤コミット防止（評価関数ファイル全般） ---
# 使用許可済みの評価関数（水匠5・Hao・リゼロ）は ShogiAI/*/eval/ 配下で明示的に管理
# それ以外の *.bin の誤コミットを防ぐ
/*.bin
/**/*.bin
!ShogiAI/*/eval/*.bin
# 本番配布用の評価関数はライセンス確認後にassets/nnueへ配置する
!assets/nnue/*.bin

# --- OS・エディタ関連 ---
.vscode/
.idea/
*.swp
